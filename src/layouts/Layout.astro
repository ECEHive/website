---
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "The Hive Makerspace | Georgia Tech IDC",
	description = "The Interdisciplinary Design Commons — Georgia Tech's makerspace providing accessible engineering space and resources for the entire GT community.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />

		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="The Hive Makerspace" />

		<!-- Fonts: Rubik (headings) + Sora (body) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300..900;1,300..900&family=Sora:wght@100..800&display=swap"
			rel="stylesheet"
		/>

		<!-- Prevent dark-mode flash: apply class before first paint -->
		<script is:inline>
			(function () {
				var stored = localStorage.getItem("hive-theme");
				var prefersDark = window.matchMedia(
					"(prefers-color-scheme: dark)",
				).matches;
				if (stored === "dark" || (!stored && prefersDark)) {
					document.documentElement.classList.add("dark");
				}
			})();
		</script>
	</head>
	<body
		class="min-h-screen bg-white dark:bg-hive-teal-dark text-gray-900 dark:text-gray-100"
	>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
	}
</style>
