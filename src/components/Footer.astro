---
/**
 * Footer — site-wide footer with links, contact info, and GT affiliation.
 */
import { Icon } from "astro-icon/components";
import { footerSections } from "../data/nav";
import { SITE } from "../data/site";

const year = new Date().getFullYear();
---

<footer
	class="bg-hive-teal dark:bg-hive-teal-dark border-t border-white/10 text-white"
>
	<div class="max-w-7xl mx-auto px-6 pt-14 pb-8">
		<!-- Top row: brand + link columns -->
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
			<!-- Brand block -->
			<div class="lg:col-span-1">
				<a
					href="/"
					class="block mb-4 w-fit"
					aria-label="The Hive Makerspace home"
				>
					<!-- Footer is always dark, so always use the dark (white-text) logo -->
					<img
						src="/hive_logo-dark.svg"
						alt="The Hive Makerspace"
						class="h-8 w-auto"
						width="414"
						height="147"
					/>
				</a>
				<p class="text-sm text-white/60 leading-relaxed mb-4">
					Creating communities,<br />building dreams.
				</p>
				<p class="text-xs text-white/40 leading-relaxed">
					Part of the <a
						href={SITE.ece.url}
						class="hover:text-hive-yellow transition-colors"
						>Georgia Tech<br />School of ECE</a
					>
				</p>
			</div>

			<!-- Nav link columns (The Hive + Resources) -->
			{
				footerSections.map((section) => (
					<div>
						<h3 class="font-heading font-semibold text-sm uppercase tracking-wider text-white/50 mb-4">
							{section.heading}
						</h3>
						<ul class="space-y-2.5">
							{section.links.map((link) => (
								<li>
									<a
										href={link.href}
										target={link.external ? "_blank" : undefined}
										rel={link.external ? "noopener noreferrer" : undefined}
										class="text-sm text-white/70 hover:text-white transition-colors duration-150 flex items-center gap-1"
									>
										{link.label}
										{link.external && (
											<Icon
												name="heroicons:arrow-top-right-on-square"
												class="w-3 h-3 opacity-40"
											/>
										)}
									</a>
								</li>
							))}
						</ul>
					</div>
				))
			}

			<!-- Contact column -->
			<div>
				<h3
					class="font-heading font-semibold text-sm uppercase tracking-wider text-white/50 mb-4"
				>
					Contact
				</h3>
				<ul class="space-y-2.5">
					<li>
						<a
							href={`mailto:${SITE.email}`}
							class="text-sm text-white/70 hover:text-white transition-colors duration-150"
						>
							{SITE.email}
						</a>
					</li>
					<li>
						<a
							href={SITE.address.mapsUrl}
							target="_blank"
							rel="noopener noreferrer"
							class="text-sm text-white/70 hover:text-white transition-colors duration-150 flex items-center gap-1"
						>
							{SITE.address.street}
							<Icon
								name="heroicons:arrow-top-right-on-square"
								class="w-3 h-3 opacity-40"
							/>
						</a>
					</li>
					<li>
						<span class="text-sm text-white/70"
							>{SITE.address.city}, {SITE.address.state}
							{SITE.address.zip}</span
						>
					</li>
					<li>
						<a
							href={SITE.mailingList}
							class="text-sm text-white/70 hover:text-white transition-colors duration-150"
						>
							Subscribe to newsletter
						</a>
					</li>
				</ul>
			</div>
		</div>

		<!-- Divider -->
		<div
			class="border-t border-white/10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4"
		>
			<p class="text-xs text-white/40">
				&copy; {year} The Hive Makerspace — Georgia Institute of Technology. All rights
				reserved.
			</p>
			<div class="flex items-center gap-1 text-xs text-white/40">
				<span>Built with</span>
				<a
					href="https://astro.build"
					target="_blank"
					rel="noopener noreferrer"
					class="hover:text-white/70 transition-colors">Astro</a
				>
				<span>&amp;</span>
				<a
					href="https://tailwindcss.com"
					target="_blank"
					rel="noopener noreferrer"
					class="hover:text-white/70 transition-colors">Tailwind</a
				>
			</div>
		</div>
	</div>
</footer>
