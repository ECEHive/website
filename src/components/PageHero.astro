---
/**
 * PageHero — gradient banner header used by interior pages.
 *
 * The gradient fills the full section from the very top of the page (y=0),
 * visually merging with the navbar that floats above it.
 * Content is offset by --header-height (set by Navbar.astro's JS) so nothing
 * is hidden behind the fixed navbar.
 *
 * Props:
 *  eyebrow  — small label above the heading (optional)
 *  title    — main page heading (h1)
 *  subtitle — subtext below the heading (optional)
 *  gradient — Tailwind gradient classes (default: from-hive-blue to-hive-cyan)
 */
interface Props {
	eyebrow?: string;
	title: string;
	subtitle?: string;
	gradient?: string;
}

const {
	eyebrow,
	title,
	subtitle,
	gradient = "from-hive-blue to-hive-cyan",
} = Astro.props;
---

<section class="relative isolate overflow-hidden text-white pb-16 md:pb-24">
	<!-- Gradient background: extends to the very top of the page so it merges
       visually with the frosted-glass navbar floating above it. -->
	<div
		class={`absolute inset-0 bg-gradient-to-br ${gradient}`}
		aria-hidden="true"
	>
	</div>

	<!-- Subtle noise overlay for depth/texture -->
	<div
		class="absolute inset-0 opacity-[0.04] bg-[url('data:image/svg+xml,%3Csvg%20viewBox%3D%220%200%20200%20200%22%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%3E%3Cfilter%20id%3D%22n%22%3E%3CfeTurbulence%20type%3D%22fractalNoise%22%20baseFrequency%3D%220.9%22%20numOctaves%3D%224%22%20stitchTiles%3D%22stitch%22/%3E%3C/filter%3E%3Crect%20width%3D%22100%25%22%20height%3D%22100%25%22%20filter%3D%22url(%23n)%22/%3E%3C/svg%3E')]"
		aria-hidden="true"
	>
	</div>

	<!-- Content: padding-top clears the fixed navbar dynamically -->
	<div
		class="relative z-10 max-w-5xl mx-auto px-6"
		style="padding-top: calc(var(--header-height, 88px) + 2.5rem)"
	>
		{
			eyebrow && (
				<p class="text-xs font-semibold uppercase tracking-[0.15em] text-white/50 mb-3 flex items-center gap-2">
					<span class="w-5 h-px bg-white/40" />
					{eyebrow}
				</p>
			)
		}
		<h1 class="font-heading text-4xl md:text-5xl font-bold mb-4 leading-tight">
			{title}
		</h1>
		{
			subtitle && (
				<p class="text-lg text-white/75 max-w-2xl leading-relaxed">
					{subtitle}
				</p>
			)
		}
	</div>
</section>
