---
/**
 * Button — reusable button / link component.
 *
 * Props:
 *  variant  — 'primary' | 'secondary' | 'outline' | 'ghost'    (default: primary)
 *  size     — 'sm' | 'md' | 'lg'                                (default: md)
 *  href     — renders an <a> tag instead of <button>
 *  external — adds target="_blank" + rel when true
 *  class    — extra classes
 */
interface Props {
	variant?:
		| "primary"
		| "secondary"
		| "outline"
		| "outline-white"
		| "ghost"
		| "ghost-white";
	size?: "sm" | "md" | "lg";
	href?: string;
	external?: boolean;
	class?: string;
	[key: string]: unknown;
}

const {
	variant = "primary",
	size = "md",
	href,
	external = false,
	class: extraClass = "",
	...rest
} = Astro.props;

const variantClasses: Record<string, string> = {
	primary:
		"bg-hive-yellow text-hive-dark font-semibold hover:bg-hive-yellow-dark active:bg-hive-yellow-dark shadow-sm",
	secondary:
		"bg-hive-blue text-white hover:bg-hive-blue-light active:bg-hive-blue-light shadow-sm",
	outline:
		"border-2 border-hive-blue text-hive-blue hover:bg-hive-blue hover:text-white dark:text-hive-cyan dark:border-hive-cyan dark:hover:bg-hive-cyan dark:hover:text-hive-dark",
	"outline-white":
		"border-2 border-white/80 text-white hover:bg-white/90 hover:text-hive-dark dark:hover:bg-white/20 dark:hover:text-white hover:border-white active:bg-white/80",
	ghost:
		"text-hive-blue hover:bg-hive-blue/10 dark:text-hive-cyan dark:hover:bg-hive-cyan/20",
	"ghost-white":
		"text-white hover:bg-white/15 dark:text-white dark:hover:bg-white/15",
};

const sizeClasses: Record<string, string> = {
	sm: "px-3.5 py-1.5 text-sm gap-1.5",
	md: "px-5 py-2.5 text-sm gap-2",
	lg: "px-7 py-3.5 text-base gap-2.5",
};

const base = `inline-flex items-center justify-center font-medium rounded-lg transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-hive-blue focus-visible:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed`;

const classes = `${base} ${variantClasses[variant]} ${sizeClasses[size]} ${extraClass}`;
---

{
	href ? (
		<a
			href={href}
			class={classes}
			target={external ? "_blank" : undefined}
			rel={external ? "noopener noreferrer" : undefined}
			{...rest}
		>
			<slot />
		</a>
	) : (
		<button class={classes} {...rest}>
			<slot />
		</button>
	)
}
