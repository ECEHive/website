---
/**
 * HoursDisplay — shows current semester hours in a clean card layout.
 *
 * Props:
 *  semester — label for the hours period (e.g. "Summer 2026")
 *  period   — date range string (e.g. "May 27 – July 23")
 *  hours    — array of { days, time } objects
 *  note     — optional note (e.g. "Closed on Institute Holidays")
 */
import { Icon } from "astro-icon/components";

interface HoursRow {
  days: string;
  time: string;
}

interface Props {
  semester: string;
  period: string;
  hours: HoursRow[];
  note?: string;
}

const { semester, period, hours, note } = Astro.props;
---

<div
  class="rounded-2xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 shadow-sm overflow-hidden"
>
  <!-- Header -->
  <div class="bg-hive-gradient px-6 py-4 text-white">
    <p
      class="text-xs font-medium uppercase tracking-widest text-white/60 mb-0.5"
    >
      Current Hours
    </p>
    <h3 class="font-heading font-bold text-xl">{semester}</h3>
    <p class="text-sm text-white/75 mt-1">{period}</p>
  </div>

  <!-- Hours rows -->
  <div class="divide-y divide-gray-100 dark:divide-white/10">
    {
      hours.map((row) => (
        <div class="flex items-center justify-between px-6 py-3.5">
          <span class="font-medium text-gray-700 dark:text-gray-300 text-sm">
            {row.days}
          </span>
          <span class="font-heading font-semibold text-hive-purple dark:text-hive-purple-light text-sm">
            {row.time}
          </span>
        </div>
      ))
    }
  </div>

  <!-- Note -->
  {
    note && (
      <div class="px-6 py-3 bg-amber-50 dark:bg-gt-gold/10 border-t border-amber-100 dark:border-gt-gold/20">
        <p class="text-xs text-amber-700 dark:text-gt-gold-light flex items-center gap-1.5">
          <Icon
            name="heroicons:information-circle"
            class="w-3.5 h-3.5 shrink-0"
          />
          {note}
        </p>
      </div>
    )
  }
</div>
