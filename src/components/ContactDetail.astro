---
/**
 * ContactDetail — icon + label + slotted content row.
 * Used in the contact page for email, location, newsletter, etc.
 *
 * Props:
 *  icon  — heroicons icon name (e.g. "heroicons:envelope")
 *  label — short uppercase section label
 */
import { Icon } from "astro-icon/components";

interface Props {
	icon: string;
	label: string;
}

const { icon, label } = Astro.props;
---

<div class="flex items-start gap-4">
	<div
		class="w-11 h-11 rounded-xl bg-hive-purple/10 dark:bg-hive-purple/20
              flex items-center justify-center shrink-0 mt-0.5"
	>
		<Icon
			name={icon}
			class="w-5 h-5 text-hive-purple dark:text-hive-purple-light"
		/>
	</div>
	<div>
		<p
			class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1"
		>
			{label}
		</p>
		<slot />
	</div>
</div>
